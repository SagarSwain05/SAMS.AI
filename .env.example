# ── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.

FLASK_ENV=production

# Server
PORT=7860

# Secret keys — generate strong random strings in production
SECRET_KEY=change-me-strong-random-secret
JWT_SECRET_KEY=change-me-strong-jwt-secret

# Database — Neon.tech PostgreSQL connection string
# Format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
# Neon provides a postgres:// URL — the app auto-converts it.
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Camera (set to -1 to disable camera on serverless deployments)
CAMERA_INDEX=0

# Face recognition confidence threshold (0.0 - 1.0)
FACE_RECOGNITION_THRESHOLD=0.85

# Optional IoT camera API key (leave blank to disable check)
IOT_CAMERA_KEY=
